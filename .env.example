# Server
HOST=0.0.0.0
PORT=8787
NODE_ENV=development

# Safety/limits
MAX_JSON_BODY_BYTES=5242880
MAX_IMAGE_BYTES=3145728

# Data persistence paths
# In local: ./data is used by default.
# In cloud (Render etc): set DATA_DIR to mounted persistent disk path (example: /var/data)
DATA_DIR=
DATA_STORE_PATH=
UPLOAD_DIR=

# Doctor auth
# In production over HTTPS, set true.
DOCTOR_COOKIE_SECURE=false
DOCTOR_DEMO_EMAIL=doctor@example.com
DOCTOR_DEMO_PASSWORD=doctor1234

# Optional: voice fallback transcription
# Set this to enable /api/v1/voice/transcribe for browsers without SpeechRecognition
OPENAI_API_KEY=
